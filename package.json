{
    "name": "@amane-app/blog-sdk",
    "version": "0.1.4",
    "description": "AMANE Blog Distribution API SDK for JavaScript/TypeScript",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amane-app/blog-sdk-js.git"
    },
    "homepage": "https://github.com/amane-app/blog-sdk-js#readme",
    "bugs": {
        "url": "https://github.com/amane-app/blog-sdk-js/issues"
    },
    "keywords": [
        "amane",
        "blog",
        "seo",
        "api-client",
        "sdk"
    ],
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "npm run build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:unit": "vitest run test/unit",
        "test:integration": "vitest run test/integration",
        "test:e2e": "vitest run test/e2e",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.9",
        "typescript": "^5.0.0",
        "vitest": "^4.1.9"
    },
    "license": "MIT"
}
